#!/usr/bin/env bash
# creds-rotation-check — send ntfy notification if any credentials are overdue
# Installed as monthly cron: 0 9 1 * * ~/.local/bin/creds-rotation-check

set -e

STALE_OUTPUT=$(creds audit --stale 2>/dev/null || true)
if [ -z "$STALE_OUTPUT" ]; then
    exit 0
fi

STALE_COUNT=$(echo "$STALE_OUTPUT" | grep -c "OVERDUE" 2>/dev/null || echo "0")
WARN_COUNT=$(echo "$STALE_OUTPUT" | grep -c "WARN" 2>/dev/null || echo "0")

if [ "$STALE_COUNT" -eq 0 ] && [ "$WARN_COUNT" -eq 0 ]; then
    exit 0
fi

# Get ntfy topic from creds
NTFY_TOPIC=$(creds get ntfy 2>/dev/null || echo "")
if [ -z "$NTFY_TOPIC" ]; then
    echo "No ntfy topic configured. Run: creds add ntfy" >&2
    exit 0
fi

MSG="${STALE_COUNT} credential(s) overdue for rotation, ${WARN_COUNT} recommended. Run: creds audit --stale"

curl -s -X POST \
    -H "Title: Credential Rotation Reminder" \
    -H "Priority: default" \
    -d "$MSG" \
    "https://ntfy.sh/$NTFY_TOPIC" \
    > /dev/null

echo "Sent rotation reminder: $MSG"
